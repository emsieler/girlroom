# Copy to `.dotenv` and fill in. Never commit `.dotenv`.

# --- R2 S3 API (required for rclone upload) ---
# Create in Cloudflare: R2 → Overview → "Manage R2 API Tokens" → Create API token
# with Object Read & Write on bucket `girl-room`. You get Access Key ID + Secret.
# "Account" vs "User" token: either works; scoped-to-bucket tokens are slightly safer.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Account ID from the S3 endpoint URL (same subdomain as *.r2.cloudflarestorage.com)
R2_ACCOUNT_ID=ef81c4ce3b1ff2806ae9bf34ad7dbae8
R2_BUCKET=girl-room

R2_ENDPOINT=https://ef81c4ce3b1ff2806ae9bf34ad7dbae8.r2.cloudflarestorage.com

# --- Public playback URL (required for data/archive.json) ---
# Enable in R2: bucket → Settings → Public access → R2.dev subdomain OR Custom domain.
# Example: https://pub-abcdef1234567890.r2.dev  OR  https://media.girlroom.com
# Do NOT use the cloudflarestorage.com host here — that is API-only, not web GET.
R2_PUBLIC_BASE=https://pub-xxxxxxxxxxxx.r2.dev

# --- Optional: Cloudflare API token (NOT used by this script for uploads) ---
# CLOUDFLARE_TOKEN is for Workers / DNS / REST API. rclone needs R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY.
